<file path="src/components/Admin/AdminSidebar.module.css">
:root {
  --admin-sidebar-font-display: 'Cormorant Garamond', serif;
  --admin-sidebar-font-sans: 'Outfit', sans-serif;
}

.sidebar {
  width: 260px;
  height: 100vh;
  background-color: var(--admin-sidebar-card);
  border-right: 1px solid var(--admin-sidebar-border);
  display: flex;
  flex-direction: column;
  position: fixed;
  left: 0;
  top: 0;
  z-index: 50;
  transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  font-family: var(--admin-sidebar-font-sans);
}

.sidebarCollapsed {
  width: 80px;
}

.sidebarCollapsed .navText,
.sidebarCollapsed .logoText,
.sidebarCollapsed .userInfo {
  opacity: 0;
  visibility: hidden;
}

.sidebarCollapsed .navItem {
  justify-content: center;
  padding-left: 0;
  padding-right: 0;
}

/* Logo Section */
.logoSection {
  height: 64px;
  display: flex;
  align-items: center;
  padding: 0 24px;
  border-bottom: 1px solid var(--admin-sidebar-border);
}

.logoWrapper {
  font-family: var(--admin-sidebar-font-display);
  font-size: 24px;
  color: var(--admin-sidebar-accent);
}

.logoTextStrong {
  font-weight: 600;
  color: var(--admin-sidebar-accent);
}

.logoTextLight {
  font-weight: 300;
  color: var(--admin-sidebar-accent);
}

/* Navigation */
.navSection {
  flex: 1;
  padding: 24px 0;
  overflow-y: auto;
}

.navSectionCategory {
  padding: 0 16px;
  margin-bottom: 16px;
}

.navSectionCategoryText {
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--admin-sidebar-fg-muted);
  padding-left: 8px;
}

.navItem {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 12px 24px;
  font-size: 14px;
  font-weight: 300;
  color: var(--admin-sidebar-fg-muted);
  text-decoration: none;
  transition: all 0.3s ease;
  cursor: pointer;
}

.navItem::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  width: 3px;
  background-color: var(--admin-sidebar-accent);
  transform: scaleY(0);
  transition: transform 0.3s ease;
}

.navItem:hover::before,
.navItemActive::before {
  transform: scaleY(1);
}

.navItem:hover {
  background-color: var(--admin-sidebar-bg-secondary);
  color: var(--admin-sidebar-fg);
}

.navItemActive {
  background-color: var(--admin-sidebar-bg-secondary);
  color: var(--admin-sidebar-fg);
}

.navItemIcon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}

.navText {
  font-size: 14px;
  font-weight: 300;
}

.navItemBadge {
  margin-left: auto;
  background-color: var(--admin-sidebar-accent);
  color: white;
  font-size: 12px;
  padding: 2px 8px;
}

/* User Section */
.userSection {
  padding: 16px;
  border-top: 1px solid var(--admin-sidebar-border);
}

.userSectionContent {
  display: flex;
  align-items: center;
  gap: 12px;
}

.userAvatar {
  width: 40px;
  height: 40px;
  background-color: var(--admin-sidebar-bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--admin-sidebar-font-display);
  font-size: 18px;
}

.userInfo {
  flex: 1;
  min-width: 0;
}

.userName {
  font-size: 14px;
  font-weight: 300;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.userRole {
  font-size: 12px;
  color: var(--admin-sidebar-fg-muted);
}

/* Custom Scrollbar */
.navSection::-webkit-scrollbar {
  width: 6px;
}

.navSection::-webkit-scrollbar-track {
  background: var(--admin-sidebar-bg);
}

.navSection::-webkit-scrollbar-thumb {
  background: var(--admin-sidebar-border);
}

.navSection::-webkit-scrollbar-thumb:hover {
  background: var(--admin-sidebar-fg-muted);
}

/* Focus states */
.navItem:focus-visible {
  outline: 2px solid var(--admin-sidebar-accent);
  outline-offset: 2px;
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  .navItem::before {
    transition-duration: 0.01ms !important;
  }
  
  .sidebar {
    transition-duration: 0.01ms !important;
  }
}
</file>

<file path="src/components/Landing/Landing.module.css">
:root {
    --landing-bg: #FAFAF8;
    --landing-bg-secondary: #F5F4F0;
    --landing-fg: #1A1A18;
    --landing-fg-muted: #6B6B65;
    --landing-accent: #C9A227;
    --landing-accent-soft: #E8D9A0;
    --landing-border: #E5E4E0;
    --landing-card: #FFFFFF;
    --landing-font-display: 'Cormorant Garamond', serif;
    --landing-font-sans: 'Outfit', sans-serif;
  }
  
  .landing * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  
  .landing {
    font-family: var(--landing-font-sans) !important;
    background-color: var(--landing-bg);
    color: var(--landing-fg);
    overflow-x: hidden;
  }
  
  .landing .font-display {
    font-family: var(--landing-font-display) !important;
  }
  
  /* Sharp edges - no border radius anywhere */
  .landing * {
    border-radius: 0 !important;
  }
  
  /* Subtle grain texture overlay */
  .grainOverlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.03;
    z-index: 1000;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }
  
  /* Reveal animations */
  .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1),
                transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }
  
  .revealDelay1 { transition-delay: 0.1s; }
  .revealDelay2 { transition-delay: 0.2s; }
  .revealDelay3 { transition-delay: 0.3s; }
  .revealDelay4 { transition-delay: 0.4s; }
  
  /* Hero text animation */
  .heroTitle span {
    display: inline-block;
    opacity: 0;
    transform: translateY(100%);
    animation: slideUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  @keyframes slideUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .heroTitle span:nth-child(1) { animation-delay: 0.3s; }
  .heroTitle span:nth-child(2) { animation-delay: 0.4s; }
  .heroTitle span:nth-child(3) { animation-delay: 0.5s; }
  
  /* Image hover effect */
  .imgContainer {
    overflow: hidden;
    position: relative;
  }
  
  .imgContainer img {
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .imgContainer:hover img {
    transform: scale(1.05);
  }
  
  .imgContainer::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,26,24,0.4) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  
  .imgContainer:hover::after {
    opacity: 1;
  }
  
  /* Navigation line animation */
  .navLink {
    position: relative;
  }
  
  .navLink::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--landing-accent);
    transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .navLink:hover::after {
    width: 100%;
  }
  
  /* Button styles */
  .btnPrimary {
    background-color: var(--landing-fg);
    color: var(--landing-bg);
    padding: 16px 40px;
    font-weight: 300;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-size: 12px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
    display: inline-block;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }
  
  .btnPrimary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background-color: var(--landing-accent);
    transition: left 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 0;
  }
  
  .btnPrimary:hover::before {
    left: 0;
  }
  
  .btnPrimary span {
    position: relative;
    z-index: 1;
  }
  
  /* Yellow accent line */
  .accentLine {
    width: 60px;
    height: 2px;
    background-color: var(--landing-accent);
  }
  
  /* Scroll indicator */
  .scrollIndicator {
    animation: bounce 2s infinite;
  }
  
  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(10px); }
    60% { transform: translateY(5px); }
  }
  
  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .landing *, .landing *::before, .landing *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
    .reveal {
      opacity: 1;
      transform: none;
    }
  }
  
  /* Focus states */
  .landing a:focus-visible, .landing button:focus-visible {
    outline: 2px solid var(--landing-accent);
    outline-offset: 4px;
  }
  
  /* Category card hover */
  .categoryCard {
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .categoryCard:hover {
    background-color: var(--landing-bg-secondary);
  }
  
  .categoryCard:hover .categoryNumber {
    color: var(--landing-accent);
  }
  
  /* Parallax effect for hero */
  .parallaxHero {
    transform: translateY(calc(var(--scroll) * 0.3px));
  }
  
  /* Navigation */
  .navigation {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 50;
    background-color: rgba(250, 250, 248, 0.9);
    backdrop-filter: blur(4px);
    border-bottom: 1px solid var(--landing-border);
  }
  
  .navContent {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }
  
  @media (min-width: 1024px) {
    .navContent {
      padding: 0 48px;
    }
  }
  
  .navInner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }
  
  .navLogo {
    font-family: var(--landing-font-display);
    font-size: 24px;
    font-weight: 300;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: var(--landing-fg);
  }
  
  .navLogo span {
    color: var(--landing-accent);
  }
  
  .navLinks {
    display: none;
    align-items: center;
    gap: 48px;
  }
  
  @media (min-width: 768px) {
    .navLinks {
      display: flex;
    }
  }
  
  .navLinkItem {
    font-size: 14px;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--landing-fg-muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .navLinkItem:hover {
    color: var(--landing-fg);
  }
  
  .menuBtn {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
  }
  
  @media (min-width: 768px) {
    .menuBtn {
      display: none;
    }
  }
  
  .menuBtn span {
    width: 24px;
    height: 1px;
    background-color: var(--landing-fg);
    transition: all 0.3s ease;
  }
  
  /* Mobile Menu */
  .mobileMenu {
    position: fixed;
    inset: 0;
    background-color: var(--landing-bg);
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }
  
  .mobileMenu.active {
    opacity: 1;
    pointer-events: auto;
  }
  
  .mobileMenuContent {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  
  .mobileMenuLink {
    display: block;
    font-family: var(--landing-font-display);
    font-size: 36px;
    font-weight: 300;
    color: var(--landing-fg);
    text-decoration: none;
  }
  
  /* Hero Section */
  .heroSection {
